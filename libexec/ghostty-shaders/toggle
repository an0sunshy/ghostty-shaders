#!/usr/bin/env bash
# ghostty-shaders toggle — pause or resume the active shader. Useful for
# presentations (no peripheral motion when projecting), screen recordings,
# or battery-saving when the weather poller isn't already pausing
# automatically. (The `toggle` subcommand; entry point is bin/ghostty-shaders.)
#
# When paused, we write an empty include (no `custom-shader` line) and
# touch a marker file. The weather poller checks the marker and skips swaps,
# so its battery-aware logic cooperates with manual pauses.
#
# Usage:
#   ghostty-shaders toggle              # toggle current state
#   ghostty-shaders toggle --pause      # explicit pause
#   ghostty-shaders toggle --resume     # explicit resume (restores last scene)
#   ghostty-shaders toggle --status     # print "paused" or "active"

set -euo pipefail

# Resolve real dir, following symlinks (~/.local/bin install). Portable:
# bare `readlink` only (no `readlink -f`, absent on BSD/macOS).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
APPLY="$SCRIPT_DIR/apply"
WEATHER="$SCRIPT_DIR/weather"

# Ghostty process matcher (ghostty_pids / ghostty_signal) — shared with the
# apply subcommand so the regression-prone matcher lives in one place.
# shellcheck source=../../scripts/ghostty-process.sh disable=SC1091
. "$REPO_DIR/scripts/ghostty-process.sh"

INCLUDE_FILE="$HOME/.config/ghostty-shaders/active.conf"
CACHE_DIR="$HOME/Library/Caches/ghostty-shaders"
PAUSE_MARKER="$CACHE_DIR/paused"
BATTERY_PAUSE_MARKER="$CACHE_DIR/paused-by-battery"
MANUAL_RESUME_MARKER="$CACHE_DIR/manual-resume-override"
LAST_SCENE_FILE="$CACHE_DIR/last-scene"

mkdir -p "$CACHE_DIR"

is_paused() { [[ -f $PAUSE_MARKER ]]; }

do_pause() {
    if is_paused; then return 0; fi
    # Remember the last scene so --resume can restore it. We extract from
    # the current include's "Active scene: NAME" comment (also matches the
    # legacy "Active scenario:" wording from a pre-rename include).
    if [[ -f $INCLUDE_FILE ]]; then
        local last
        last=$(grep -oE 'Active scen[a-z]*:[[:space:]]*[^[:space:]]+' "$INCLUDE_FILE" \
               | awk '{print $NF}' | head -1 || true)
        [[ -n $last ]] && echo "$last" > "$LAST_SCENE_FILE"
    fi
    # Write a no-shader include: the `?` prefix in main config means
    # Ghostty silently accepts a file with no custom-shader line.
    cat > "$INCLUDE_FILE" <<EOF
# Generated by ghostty-shaders toggle; shader paused.
# Run \`ghostty-shaders toggle --resume\` to restore.
EOF
    ghostty_signal
    touch "$PAUSE_MARKER"
    echo "paused (shader off)"
}

do_resume() {
    if ! is_paused; then return 0; fi
    rm -f "$PAUSE_MARKER" "$BATTERY_PAUSE_MARKER"
    # Mark this as a user-initiated resume. The poller honors this and
    # won't re-pause due to PAUSE_ON_BATTERY until the next AC-to-battery
    # transition (i.e., the override holds until you plug in). Without
    # this, an immediate poll on battery would just re-pause us.
    touch "$MANUAL_RESUME_MARKER"

    # Apply the last cached scene directly instead of calling the weather
    # poller, to avoid any chance of immediate auto-pause races.
    if [[ -f $LAST_SCENE_FILE ]]; then
        local last
        last=$(cat "$LAST_SCENE_FILE")
        "$APPLY" "$last" >/dev/null
        echo "resumed: $last (battery auto-pause overridden until next AC)"
    elif "$WEATHER" >/dev/null 2>&1; then
        echo "resumed (weather poller picked scene)"
    else
        echo "resumed (no last scene cached; next poll will set one)"
    fi
}

case "${1:-}" in
    --pause)  do_pause ;;
    --resume) do_resume ;;
    --status)
        if is_paused; then
            echo "paused"
            [[ -f $LAST_SCENE_FILE ]] && echo "  last scene was: $(cat "$LAST_SCENE_FILE")"
        else
            echo "active"
            [[ -f $INCLUDE_FILE ]] && \
                grep -E 'Active scen[a-z]*:' "$INCLUDE_FILE" | sed 's/^# */  /'
        fi ;;
    "")       if is_paused; then do_resume; else do_pause; fi ;;
    *)        echo "usage: ghostty-shaders toggle [--pause|--resume|--status]" >&2; exit 1 ;;
esac
