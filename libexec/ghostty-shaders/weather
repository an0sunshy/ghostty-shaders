#!/usr/bin/env bash
# ghostty-shaders weather — manage the 5-minute background poller and the
# user's location. The poller itself is `select`, which matches a poem scene
# to live conditions (weather, time of day, season, festival proximity) and
# hot-reloads Ghostty. This script installs/removes that LaunchAgent and owns
# location configuration; it no longer renders weather scenes.
#
# Location is read by the shared location lib (scripts/location-lib.sh) from:
#   1. ~/.config/ghostty-shaders/config.env — LAT/LON (no 3P call) or LOCATION
#      (a city / US ZIP geocoded ONCE via Open-Meteo and cached).
#   2. ~/.config/ghostty-shaders/location.json — the geocoded cache, also
#      written by `set-city`.
# If neither has a usable value, the poller falls back to NYC with a warning.
#
# Subcommands (via bin/ghostty-shaders):
#   weather on               install the LaunchAgent (5-min interval)
#   weather off              remove the LaunchAgent
#   weather set-city <name>  geocode a city/ZIP and cache it
#
# Self-install: `weather on` generates a launchd plist that runs `select
# --cron`; `weather off` reverses it.

set -euo pipefail

# Resolve real path, following symlinks (~/.local/bin install). Portable:
# bare `readlink` only (no `readlink -f`, absent on BSD/macOS).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

CACHE_DIR="$HOME/Library/Caches/ghostty-shaders"
LOG_DIR="$HOME/Library/Logs"
LOG_FILE="$LOG_DIR/ghostty-shaders-poll.log"

# Location paths (defined here so they read clearly; the sourced lib honors
# pre-set values via `: "${VAR:=…}"`, so there is still one source of truth).
LOC_DIR="$HOME/.config/ghostty-shaders"
LOC_FILE="$LOC_DIR/location.json"
ENV_FILE="$LOC_DIR/config.env"

PLIST_LABEL="dev.ghostty-shaders.poll"
PLIST_FILE="$HOME/Library/LaunchAgents/$PLIST_LABEL.plist"
POLL_INTERVAL="${GHOSTTY_SHADERS_POLL_INTERVAL:-300}"   # 5 min; override at `weather on`

log() { printf '%s ghostty-shaders weather: %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" >&2; }

# Location resolution + geocoding live in the shared lib (the same one the
# weather provider and select use), so there is one source of truth. It also
# defines LOC_DIR / LOC_FILE / ENV_FILE / FALLBACK_LAT / FALLBACK_LON.
# shellcheck source=../../scripts/location-lib.sh disable=SC1091
. "$REPO_DIR/scripts/location-lib.sh"

# When sourced (by tests/run-tests.sh) stop here: everything above is
# definitions; everything below acts on the system.
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    return 0
fi

# ---------------------------------------------------------------- install

if [[ "${1:-}" == "--install" ]]; then
    mkdir -p "$(dirname "$PLIST_FILE")" "$LOG_DIR" "$LOC_DIR" "$CACHE_DIR"
    # The LaunchAgent drives the `select` matcher (poem chosen from live
    # conditions). `weather on/off` remains the poller toggle and owns location.
    cat > "$PLIST_FILE" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>$PLIST_LABEL</string>
    <key>ProgramArguments</key>
    <array>
        <string>$SCRIPT_DIR/select</string>
        <string>--cron</string>
    </array>
    <key>StartInterval</key>
    <integer>$POLL_INTERVAL</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>$LOG_FILE</string>
    <key>StandardErrorPath</key>
    <string>$LOG_FILE</string>
</dict>
</plist>
EOF
    launchctl unload "$PLIST_FILE" 2>/dev/null || true
    launchctl load "$PLIST_FILE"
    echo "installed: $PLIST_FILE"
    echo "  log:      $LOG_FILE"
    echo "  next run: immediately (RunAtLoad), then every ${POLL_INTERVAL}s"

    # Seed an example config.env if none exists, so users know exactly where
    # and how to set their location.
    if [[ ! -f $ENV_FILE && ! -f $LOC_FILE ]]; then
        cat > "$ENV_FILE" <<'EOF'
# ghostty-shaders location config. Set ONE of the following.
#
# Direct coordinates (recommended — never calls a 3P API for location):
# LAT=47.6062
# LON=-122.3321
#
# Or a city / US ZIP code (geocoded ONCE via Open-Meteo, cached forever
# in location.json next to this file — no recurring location call):
# LOCATION=98101
# LOCATION="Seattle, WA"
EOF
        echo "  seeded: $ENV_FILE (edit it to set your location)"
    fi

    # Surface the silent-NYC-fallback at the one moment a human is watching.
    if ! location_is_set; then
        printf '\n⚠  No location set — the poller will use New York City\n'
        printf '   (%s, %s) until you set yours:\n' "$FALLBACK_LAT" "$FALLBACK_LON"
        printf '     ghostty-shaders weather set-city "Your City"\n'
        printf '   (or put LAT/LON or LOCATION in %s)\n' "$ENV_FILE"
    fi
    exit 0
fi

if [[ "${1:-}" == "--uninstall" ]]; then
    launchctl unload "$PLIST_FILE" 2>/dev/null || true
    rm -f "$PLIST_FILE"
    echo "uninstalled: $PLIST_FILE"
    exit 0
fi

if [[ "${1:-}" == "--set-city" ]]; then
    CITY="${2:-}"
    [[ -n $CITY ]] || { echo "usage: $0 --set-city <city name>" >&2; exit 1; }
    # Reuse the shared geocoder (Open-Meteo /v1/search — no key, no IP guess);
    # it writes location.json and sets LAT/LON/GEO_NAME.
    if geocode_to_cache "$CITY"; then
        echo "set location: ${GEO_NAME:-$CITY} ($LAT, $LON) → $LOC_FILE"
    else
        echo "no match for '$CITY' from Open-Meteo geocoding" >&2
        exit 1
    fi
    exit 0
fi

# --help / bare / unknown: show usage.
sed -n 's/^# \?//; 1,/^$/p' "$0" | head -24
echo
echo "  ghostty-shaders weather on               install the poller (5-min interval)"
echo "  ghostty-shaders weather off              remove the poller"
echo "  ghostty-shaders weather set-city <name>  geocode + save location"
echo
echo "Location config: $ENV_FILE"
echo "  LAT=...  LON=...     direct coords, no 3P geocoding call"
echo "  LOCATION=98101       city or US ZIP, geocoded ONCE and cached"
echo
echo "Pick a poem now (manual match):  ghostty-shaders select"
