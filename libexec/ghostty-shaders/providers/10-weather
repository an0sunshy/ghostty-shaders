#!/usr/bin/env bash
# 10-weather — live-weather provider. Resolves the user's location, fetches
# Open-Meteo current_weather, and emits
#   {"weather":CLASS,"weather_code":N,"is_day":0|1,"temp_c":T,"wind":W}
# CLASS ∈ {clear,cloud,fog,rain,snow,storm}. On network failure it reuses a
# fresh (<6h) cached response; with neither it emits nothing (offline ⇒ the
# matcher simply falls back to time/season/festival facts).
#
# Test seam: GHOSTTY_SHADERS_WEATHER_JSON — path to a canned API response,
# used instead of curl (no network in tests).
set -euo pipefail

# Pure: WMO weather_code → coarse class. Mirrors the ranges the old weather
# poller used, but yields a class string (a fact), not a scene name.
weather_class() {
    case "$1" in
        0|1)                                   echo clear ;;
        2|3)                                   echo cloud ;;
        45|48)                                 echo fog ;;
        51|53|55|56|57|61|63|65|66|67|80|81|82) echo rain ;;
        71|73|75|77|85|86)                     echo snow ;;
        95|96|99)                              echo storm ;;
        *)                                     echo clear ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then return 0; fi

command -v jq >/dev/null 2>&1 || exit 0     # JSON assembly needs jq

DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
REPO_DIR="$(cd "$DIR/../../.." && pwd)"
CACHE_DIR="$HOME/Library/Caches/ghostty-shaders"
CACHE_FILE="$CACHE_DIR/cache.json"
CACHE_MAX_STALE=$((6 * 3600))

RESPONSE=""
if [[ -n ${GHOSTTY_SHADERS_WEATHER_JSON:-} && -f ${GHOSTTY_SHADERS_WEATHER_JSON:-} ]]; then
    RESPONSE=$(cat "$GHOSTTY_SHADERS_WEATHER_JSON")
else
    # shellcheck source=../../../scripts/location-lib.sh disable=SC1091
    . "$REPO_DIR/scripts/location-lib.sh"
    read_location
    URL="https://api.open-meteo.com/v1/forecast?latitude=${LAT}&longitude=${LON}&current_weather=true&timezone=auto"
    RESPONSE=$(curl -sf -m 10 "$URL" || true)
    if [[ -z $RESPONSE ]]; then
        if [[ -f $CACHE_FILE ]] && (( $(date +%s) - $(stat -f %m "$CACHE_FILE" 2>/dev/null || echo 0) < CACHE_MAX_STALE )); then
            RESPONSE=$(cat "$CACHE_FILE")
        else
            exit 0   # offline + no fresh cache ⇒ no weather facts
        fi
    else
        mkdir -p "$CACHE_DIR"
        printf '%s' "$RESPONSE" > "$CACHE_FILE"
    fi
fi

CODE=$(jq -r '.current_weather.weathercode  // empty' <<<"$RESPONSE")
IS_DAY=$(jq -r '.current_weather.is_day      // empty' <<<"$RESPONSE")
TEMP=$(jq -r '.current_weather.temperature   // empty' <<<"$RESPONSE")
WIND=$(jq -r '.current_weather.windspeed     // empty' <<<"$RESPONSE")
[[ -n $CODE ]] || exit 0

jq -n \
    --arg     weather      "$(weather_class "$CODE")" \
    --argjson weather_code "${CODE:-null}" \
    --argjson is_day       "${IS_DAY:-null}" \
    --argjson temp_c       "${TEMP:-null}" \
    --argjson wind         "${WIND:-null}" \
    '{weather:$weather, weather_code:$weather_code, is_day:$is_day, temp_c:$temp_c, wind:$wind}
     | with_entries(select(.value != null))'
