#!/usr/bin/env bash
# ghostty-weather-toggle — pause or resume the weather shader. Useful for
# presentations (no peripheral motion when projecting), screen recordings,
# or battery-saving when ghostty-weather-poll isn't already pausing
# automatically.
#
# When paused, we write an empty include (no `custom-shader` line) and
# touch a marker file. The poller checks the marker and skips swaps,
# so battery-aware logic in the poller cooperates with manual pauses.
#
# Usage:
#   ghostty-weather-toggle              # toggle current state
#   ghostty-weather-toggle --pause      # explicit pause
#   ghostty-weather-toggle --resume     # explicit resume (calls poller to
#                                       # re-apply current weather scene)
#   ghostty-weather-toggle --status     # print "paused" or "active"

set -euo pipefail

# Resolve real dir, following symlinks (~/.local/bin install). Portable:
# bare `readlink` only (no `readlink -f`, absent on BSD/macOS).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
POLL="$SCRIPT_DIR/ghostty-weather-poll"

INCLUDE_FILE="$HOME/.config/ghostty-weather/active.conf"
CACHE_DIR="$HOME/Library/Caches/ghostty-weather"
PAUSE_MARKER="$CACHE_DIR/paused"
BATTERY_PAUSE_MARKER="$CACHE_DIR/paused-by-battery"
MANUAL_RESUME_MARKER="$CACHE_DIR/manual-resume-override"
LAST_SCENE_FILE="$CACHE_DIR/last-scene"

mkdir -p "$CACHE_DIR"

is_paused() { [[ -f $PAUSE_MARKER ]]; }

# Mirrors ghostty-weather-swap (see there for the unit-tested matcher and
# the full rationale): NOT `pgrep -x ghostty`, because a .app-bundle launch
# names the process by its full executable path, which pgrep truncates to
# 16 chars (`/Applications/Gh…`) and never matches. Parse `ps -o comm` and
# match the exact basename instead; excludes our `ghostty-weather-*` helpers.
ghostty_pids_from_ps() {
    awk '{ pid=$1; sub(/^[[:space:]]*[0-9]+[[:space:]]+/, "")
           n=split($0, a, "/"); if (a[n] == "ghostty") print pid }'
}
ghostty_pids() { ps -axo pid=,comm= -U "$(id -u)" | ghostty_pids_from_ps || true; }

ghostty_signal() {
    local pids
    pids=$(ghostty_pids)
    # Guard with an explicit `if`, not `[[ -n $pids ]] && kill …`: when no
    # Ghostty is running the && short-circuit returns non-zero, which under
    # `set -e` would abort do_pause *before* it writes the pause marker —
    # leaving active.conf shaderless while --status still reports "active".
    if [[ -n $pids ]]; then
        # shellcheck disable=SC2086  # multi-PID list; word-splitting is intended
        kill -USR2 $pids
    fi
}

do_pause() {
    if is_paused; then return 0; fi
    # Remember the last scene so --resume can restore it. We extract from
    # the current include's "Active scenario: NAME" comment.
    if [[ -f $INCLUDE_FILE ]]; then
        local last
        last=$(grep -oE 'Active scenario:[[:space:]]*[a-z0-9-]+' "$INCLUDE_FILE" \
               | awk '{print $NF}' | head -1 || true)
        [[ -n $last ]] && echo "$last" > "$LAST_SCENE_FILE"
    fi
    # Write a no-shader include: the `?` prefix in main config means
    # Ghostty silently accepts a file with no custom-shader line.
    cat > "$INCLUDE_FILE" <<EOF
# Generated by ghostty-weather-toggle; weather shader paused.
# Run \`ghostty-weather-toggle --resume\` to restore.
EOF
    ghostty_signal
    touch "$PAUSE_MARKER"
    echo "paused (shader off)"
}

do_resume() {
    if ! is_paused; then return 0; fi
    rm -f "$PAUSE_MARKER" "$BATTERY_PAUSE_MARKER"
    # Mark this as a user-initiated resume. The poller honors this and
    # won't re-pause due to PAUSE_ON_BATTERY until the next AC-to-battery
    # transition (i.e., the override holds until you plug in). Without
    # this, an immediate poll on battery would just re-pause us.
    touch "$MANUAL_RESUME_MARKER"

    # Swap directly to the last cached scene instead of calling the
    # poller, to avoid any chance of immediate auto-pause races.
    if [[ -f $LAST_SCENE_FILE ]]; then
        local last
        last=$(cat "$LAST_SCENE_FILE")
        "$SCRIPT_DIR/ghostty-weather-swap" "$last" >/dev/null
        echo "resumed: $last (battery auto-pause overridden until next AC)"
    elif "$POLL" >/dev/null 2>&1; then
        echo "resumed (poller picked scene)"
    else
        echo "resumed (no last scene cached; next poll will set one)"
    fi
}

case "${1:-}" in
    --pause)  do_pause ;;
    --resume) do_resume ;;
    --status)
        if is_paused; then
            echo "paused"
            [[ -f $LAST_SCENE_FILE ]] && echo "  last scene was: $(cat "$LAST_SCENE_FILE")"
        else
            echo "active"
            [[ -f $INCLUDE_FILE ]] && \
                grep -E 'Active scenario:' "$INCLUDE_FILE" | sed 's/^# */  /'
        fi ;;
    "")       if is_paused; then do_resume; else do_pause; fi ;;
    *)        echo "usage: $(basename "$0") [--pause|--resume|--status]" >&2; exit 1 ;;
esac
