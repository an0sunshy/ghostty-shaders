#!/usr/bin/env bash
# ghostty-weather-demo — cycle through every weather scene for visual
# review. Each scene displays for DURATION seconds (default 10) before
# swapping to the next. Loops until Ctrl-C.
#
# Usage:
#   ghostty-weather-demo            # default 10s per scene
#   ghostty-weather-demo 15         # 15s per scene

set -euo pipefail

# Resolve real dir, following symlinks (~/.local/bin install). Portable.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
SWAP="$SCRIPT_DIR/ghostty-weather-swap"
DURATION="${1:-10}"

# Scenes to cycle. Add new ones here as they're authored.
SCENES=(clear-day clear-night cloudy rain snow thunderstorm)

if ! [[ "$DURATION" =~ ^[0-9]+$ ]]; then
    echo "usage: $(basename "$0") [seconds-per-scene]" >&2
    exit 1
fi

trap 'echo; echo "demo stopped."; exit 0' INT
echo "demo: cycling ${#SCENES[@]} scenes, $DURATION s each. Ctrl-C to stop."
while true; do
    for scene in "${SCENES[@]}"; do
        echo "  $(date +%T) → $scene"
        "$SWAP" "$scene" >/dev/null
        sleep "$DURATION"
    done
done
