# Host-local runtime state is generated OUTSIDE the repo
# (~/.config/ghostty-weather/ and ~/Library/Caches/ghostty-weather/). These
# entries just guard against stray copies and editor noise inside the tree.
active.conf

# Diagnostic scenes used while debugging the pipeline — never tracked.
# e.g. _test-red.glsl, _test-sky.glsl, _test-quadrant.glsl
shaders/scenes/_test-*.glsl

.DS_Store

# Compiled benchmark binaries — rebuilt on demand by bench/*.sh.
bench/glsl_bench
bench/glsl_image

# Assembled gallery site — rebuilt on demand by scripts/build-site.sh.
/_site/

# Vendored stb single-header libs — fetched on demand by bench/golden.sh.
# (bench/golden/*.png and bench/baseline.json ARE tracked.)
bench/vendor/
